{
  "manifest_version": 3,
  "name": "Iskra",
  "version": "2.0",
  "description": "Analyze news in ChatGPT and sync final responses to Watchlist.",
  "permissions": [
    "tabs",
    "tabGroups",
    "scripting",
    "contextMenus",
    "storage",
    "alarms",
    "clipboardRead",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://*.economist.com/*",
    "https://epoch.ai/*",
    "https://*.epoch.ai/*",
    "https://asia.nikkei.com/*",
    "https://*.caixinglobal.com/*",
    "https://*.theafricareport.com/*",
    "https://*.nzz.ch/*",
    "https://*.project-syndicate.org/*",
    "https://the-ken.com/*",
    "https://*.lazard.com/*",
    "https://*.rand.org/*",
    "https://*.wsj.com/*",
    "https://*.foreignaffairs.com/*",
    "https://*.barrons.com/*",
    "https://open.spotify.com/*",
    "https://mail.google.com/*",
    "https://iskierka-watchlist.duckdns.org/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://iskierka-watchlist.duckdns.org/*",
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": [
        "dashboard-bridge-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Iskra",
    "default_popup": "popup.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      }
    },
    "open_responses": {
      "suggested_key": {
        "default": "Ctrl+Shift+R"
      },
      "description": "Otworz zebrane odpowiedzi"
    },
    "open_process_monitor": {
      "suggested_key": {
        "default": "Ctrl+Shift+M"
      },
      "description": "Otworz panel procesow"
    }
  }
}
