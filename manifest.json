{
  "manifest_version": 3,
  "minimum_chrome_version": "120",
  "name": "Iskra",
  "version": "2.0",
  "description": "Analyze news in ChatGPT and sync final responses to Watchlist.",
  "permissions": [
    "tabs",
    "tabGroups",
    "scripting",
    "contextMenus",
    "storage",
    "alarms",
    "permissions"
  ],
  "host_permissions": [
    "https://*.economist.com/*",
    "https://epoch.ai/*",
    "https://*.epoch.ai/*",
    "https://asia.nikkei.com/*",
    "https://*.caixinglobal.com/*",
    "https://*.theafricareport.com/*",
    "https://*.nzz.ch/*",
    "https://*.project-syndicate.org/*",
    "https://the-ken.com/*",
    "https://*.lazard.com/*",
    "https://*.rand.org/*",
    "https://*.wsj.com/*",
    "https://*.foreignaffairs.com/*",
    "https://*.barrons.com/*",
    "https://open.spotify.com/*",
    "https://iskierka-watchlist.duckdns.org/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://chatgpt.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Iskra",
    "default_popup": "popup.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      }
    },
    "open_responses": {
      "suggested_key": {
        "default": "Ctrl+Shift+R"
      },
      "description": "Otworz zebrane odpowiedzi"
    },
    "open_process_monitor": {
      "suggested_key": {
        "default": "Ctrl+Shift+M"
      },
      "description": "Otworz panel procesow"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["prompt-dialog.html", "prompt-dialog.js", "manual-source.html", "manual-source.js", "responses.html", "responses.js", "prompts-company.txt", "process-monitor.html", "process-monitor.js", "chatgpt-monitor.js", "reload-resume-monitor.html", "reload-resume-monitor.js", "unfinished-processes.html", "unfinished-processes.js"],
      "matches": ["<all_urls>"]
    }
  ]
}

